<div class="d-flex justify-content-center align-items-center" style="min-height: 320px; padding: 2rem 0;">
  <div class="card text-center p-4" style="max-width: 380px; width: 100%;">
    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3"
         style="width: 56px; height: 56px;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <rect x="4" y="4"  width="16" height="3" rx="1" fill="#aaa"/>
        <rect x="4" y="10" width="16" height="2" rx="1" fill="#aaa"/>
        <rect x="4" y="15" width="10" height="2" rx="1" fill="#aaa"/>
      </svg>
    </div>
    <h6 class="fw-medium mb-1">No articles found</h6>
    <p class="text-muted small mb-4">
      There are no articles yet. Create your first one to get started.
    </p>
    <%= link_to new_article_path, class: "btn btn-outline-secondary btn-sm" do %>
      <svg width="12" height="12" viewBox="0 0 14 14" fill="none" class="me-1">
        <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Create new article
    <% end %>
  </div>
</div>
