<%= render 'layouts/messages' %>
<div class="container ">
  <h1 class="text-center mt-4">Article Details</h1>
  <div class="row justify-content-md-center">
    <div class="col-8 mt-4 ">
      <div class="card text-center shadow bg-body rounded">
        <div class="card-header fst-italic">
          by <%= link_to (@article.user.username if @article.user), @article.user, class: 'text-decoration-none' %>
          <br>
          <span class="rounded-circle shadow d-inline-block overflow-hidden text-decoration-none mt-3">
            <%= link_to  gravatar_for( @article.user) ,@article.user, class: 'text-decoration-none ' %>
          </span>
        </div>
        <div class="card-body">
          <h5 class="card-title"><%= link_to  @article.title, article_path(@article), class:'text-success text-decoration-none' %></h5>
          <div class="card-text text-start"><%= simple_format(@article.description) %></div>
          <% if logged_in? && (@article.user == current_user || current_user.admin?) %>
            <%= link_to  'Edit', edit_article_path(@article), class:'btn btn-outline-info text-decoration-none' %>
            <%= link_to  'Delete', article_path(@article),data:{ turbo_method: :delete, turbo_confirm: "Are you sure?" }, class:'btn btn-outline-danger text-decoration-none' %>
          <% end %>
        </div>
        <div class="card-footer text-body-secondary">
          Created <%= time_ago_in_words(@article.created_at) %> ago, Updated <%= time_ago_in_words(@article.updated_at) %> ago
        </div>
      </div>
    </div>
  </div>
</div>
