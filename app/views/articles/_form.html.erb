.
<div class="container">
  <div class="row justify-content-center">
    <div class="col-10">
      <%= render 'shared/errors', obj: article %>
      <%= form_with(model: article, local: true,data: { turbo: false }, class:'shadow p-3 mb-3 bg-info rounded' ) do |form| %>
        <div class="form-group row">
          <%= form.label :title, class: 'col-2 col-form-label text-white' %>
          <div class="col-10">
            <%= form.text_field :title, class: 'form-control shadow rounded', placeholder: "Title of Article" %>
          </div>
        </div>
        <div class="form-group row mt-4">
          <%= form.label :description, class: 'col-2 col-form-label text-white' %>
          <div class="col-10" >
            <%= form.text_area :description, rows: 10, class: 'form-control shadow rounded', placeholder: "Description of Article" %>
          </div>
        </div>
        <div class="form-group row mt-4">
          <%= form.label :category, class: 'col-2 col-form-label text-white' %>
          <%= form.collection_select(:category_ids, Category.all, :id, :name, { prompt: "please select the category(can be empty)" }, { multiple: true, size: 3 , class:'custom-select shadow rounded'}) %>
        </div>
        <div class="from-group text-center mt-4">
          <%= form.submit class:"btn btn-outline-light btn-lg" %>
        </div>
      <% end %>
    </div>
    <div class="text-center mt-2 mb-5">
      <%= link_to '[ Cancel and return To Articles ]', articles_path, class:'text-info' %>
    </div>
  </div>
</div>
